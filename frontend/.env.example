# Backend origin — only needed when the frontend is deployed separately from
# the backend (e.g. frontend on Vercel, backend on Render/Railway). Leave
# empty for the single-process deploy or local dev (Vite proxies /auth and
# /analyze to localhost:8000 — see vite.config.ts).
VITE_API_BASE_URL=

# Error tracking — optional. A no-op until set (Sentry SDK just doesn't init).
VITE_SENTRY_DSN=

# Cloudflare Turnstile site key — optional. Registration works without a
# CAPTCHA challenge until this is set (see app/config.py TURNSTILE_SITE_KEY /
# TURNSTILE_SECRET_KEY for the matching backend half).
VITE_TURNSTILE_SITE_KEY=
