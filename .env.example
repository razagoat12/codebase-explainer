# NVIDIA API key — get one at https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# Optional — extra NVIDIA keys (comma-separated) pooled alongside NVIDIA_API_KEY.
# Each free key has its own per-minute rate limit, so pooling several multiplies
# how many analyses can run concurrently before requests start getting rate-limited.
# Leave empty to run on a single key.
NVIDIA_API_KEYS=

# Fallback chain — tried in order (this one, then GLM, then DeepSeek below)
# once the primary NVIDIA key pool is exhausted or rate-limited ("queue is
# full"). Each is independently optional; leave a key empty to skip it.
FALLBACK_API_KEY=
FALLBACK_BASE_URL=https://integrate.api.nvidia.com/v1
FALLBACK_MODEL=moonshotai/kimi-k2.6

GLM_API_KEY=
GLM_BASE_URL=https://integrate.api.nvidia.com/v1
GLM_MODEL=z-ai/glm-5.2

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://integrate.api.nvidia.com/v1
DEEPSEEK_MODEL=deepseek-ai/deepseek-v4-pro

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database — SQLite is the default for local dev (no setup required).
# For production or higher concurrency, swap to PostgreSQL:
#   DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/codebase_explainer
DATABASE_URL=sqlite+aiosqlite:///./codebase_explainer.db

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate limiting — analysis requests per hour per user
RATE_LIMIT_PER_HOUR=10

# Ingestion limits
MAX_FILE_SIZE_BYTES=512000
MAX_TOTAL_CONTENT_BYTES=2097152

# Queue — set USE_CELERY=true to dispatch analyses via Celery+Redis instead of BackgroundTasks.
# Requires Redis running (brew install redis && brew services start redis).
USE_CELERY=false
REDIS_URL=redis://localhost:6379/0

# Error tracking — optional. A no-op until set (Sentry SDK just doesn't init).
SENTRY_DSN=

# Cloudflare Turnstile — optional abuse guard on /auth/register. Registration
# works without a CAPTCHA challenge until both are set. Get keys at
# https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
