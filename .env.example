# NVIDIA API key — get one at https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database — SQLite is the default for local dev (no setup required).
# For production or higher concurrency, swap to PostgreSQL:
#   DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/codebase_explainer
DATABASE_URL=sqlite+aiosqlite:///./codebase_explainer.db

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate limiting — analysis requests per hour per user
RATE_LIMIT_PER_HOUR=10

# Ingestion limits
MAX_FILE_SIZE_BYTES=512000
MAX_TOTAL_CONTENT_BYTES=2097152

# Queue — set USE_CELERY=true to dispatch analyses via Celery+Redis instead of BackgroundTasks.
# Requires Redis running (brew install redis && brew services start redis).
USE_CELERY=false
REDIS_URL=redis://localhost:6379/0
